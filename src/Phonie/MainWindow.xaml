<Window x:Class="Phonie.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="PHONIE - DEV0.2.4"
        Icon="Assets/Phonie.ico"
        Width="1380"
        Height="860"
        MinWidth="1180"
        MinHeight="800"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        StateChanged="MainWindow_OnStateChanged">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38"
                            ResizeBorderThickness="7"
                            CornerRadius="8"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource WindowBackground}"
            BorderBrush="{DynamicResource PanelBorder}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource ChromeBackground}"
                    BorderBrush="{DynamicResource Divider}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Image Source="Assets/PhonieIcon.png" Width="22" Height="22" Margin="0,0,8,0" />
                        <TextBlock Text="PHONIE - DEV0.2.4"
                                   Foreground="{DynamicResource PrimaryText}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource ChromeButtonStyle}"
                            Content="&#xE921;"
                            ToolTip="Réduire"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="MinimizeButton_OnClick" />
                    <Button x:Name="MaximizeButton"
                            Grid.Column="2"
                            Style="{StaticResource ChromeButtonStyle}"
                            Content="&#xE922;"
                            ToolTip="Agrandir"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="MaximizeButton_OnClick" />
                    <Button Grid.Column="3"
                            Style="{StaticResource ChromeButtonStyle}"
                            Content="&#xE8BB;"
                            ToolTip="Fermer"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="CloseButton_OnClick" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="16,13,16,13">
                <Grid.RowDefinitions>
                    <RowDefinition Height="54" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="54" />
                    <RowDefinition Height="7" />
                    <RowDefinition Height="31" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="160" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" MinHeight="180" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="158" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="36" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Assets/PhonieIcon.png" Width="46" Height="46" Margin="0,0,12,0" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="PHONIE" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" />
                            <TextBlock Text="DEV0.2.4 - UI PREMIUM - MODE PORTABLE"
                                       Foreground="{DynamicResource Accent}"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Margin="0,1,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="APPARENCE" Style="{StaticResource LabelStyle}" Margin="0,0,0,3" />
                        <ComboBox x:Name="ThemeComboBox"
                                  Width="122"
                                  SelectionChanged="ThemeComboBox_OnSelectionChanged">
                            <ComboBoxItem Content="Sombre" Tag="Dark" />
                            <ComboBoxItem Content="Clair" Tag="Light" />
                        </ComboBox>
                    </StackPanel>

                    <Button Grid.Column="3"
                            Style="{StaticResource AccentButtonStyle}"
                            Content="Forcer la reconnexion"
                            MinWidth="166"
                            Height="33"
                            VerticalAlignment="Bottom"
                            Click="ReconnectButton_OnClick" />
                </Grid>

                <Border Grid.Row="2" Style="{StaticResource CompactCardStyle}" Background="{DynamicResource StatusStripBackground}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource AccentSoft}" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusDot" Width="9" Height="9" Fill="{DynamicResource Warning}" />
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock x:Name="ConnectionText" Text="En attente du simulateur" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock Text="Connexion locale automatique - MSFS 2020 et 2024 - aucun ordre de lancement imposé"
                                       Style="{StaticResource SubtitleStyle}" Margin="0,2,0,0" />
                        </StackPanel>
                        <TextBlock x:Name="LastUpdateText"
                                   Grid.Column="3"
                                   Text="Aucune donnée"
                                   Foreground="{DynamicResource SecondaryText}"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Grid.Row="4"
                        Background="{DynamicResource AccentSoft}"
                        BorderBrush="{DynamicResource Accent}"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="11,6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE946;" Style="{StaticResource IconTextStyle}" FontSize="13" />
                        <TextBlock Text="Désactiver l'ATC et les voix ATC de Microsoft Flight Simulator avant d'utiliser PHONIE."
                                   Foreground="{DynamicResource PrimaryText}"
                                   FontSize="11" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.18*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="1.18*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="0.92*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="33" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="33" />
                                <RowDefinition Height="5" />
                                <RowDefinition Height="4" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE720;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="MICROPHONE" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            </StackPanel>
                            <ComboBox x:Name="InputDeviceComboBox"
                                      Grid.Row="2"
                                      SelectionChanged="InputDeviceComboBox_OnSelectionChanged" />
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="112" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="NIVEAU APRÈS GAIN" Style="{StaticResource LabelStyle}" FontSize="9" />
                                    <ProgressBar x:Name="MicrophoneLevelBar" Minimum="0" Maximum="100" Value="0" Margin="0,5,0,0" />
                                </StackPanel>
                                <ComboBox x:Name="GainComboBox"
                                          Grid.Column="2"
                                          SelectionChanged="GainComboBox_OnSelectionChanged">
                                    <ComboBoxItem Content="0 dB" Tag="0" />
                                    <ComboBoxItem Content="+3 dB" Tag="3" />
                                    <ComboBoxItem Content="+6 dB" Tag="6" />
                                    <ComboBoxItem Content="+9 dB" Tag="9" />
                                    <ComboBoxItem Content="+12 dB" Tag="12" />
                                    <ComboBoxItem Content="+15 dB" Tag="15" />
                                    <ComboBoxItem Content="+18 dB" Tag="18" />
                                </ComboBox>
                            </Grid>
                            <TextBlock x:Name="MicrophoneSaturationText"
                                       Grid.Row="7"
                                       Text="Gain PHONIE : +6 dB - signal en attente"
                                       Style="{StaticResource SubtitleStyle}"
                                       Margin="0" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="7" />
                                <RowDefinition Height="33" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="33" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE767;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="SORTIE RADIO" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            </StackPanel>
                            <ComboBox x:Name="OutputDeviceComboBox"
                                      Grid.Row="2"
                                      SelectionChanged="OutputDeviceComboBox_OnSelectionChanged" />
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="96" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="PlayLastRecordingButton"
                                        Content="Écouter le dernier PTT"
                                        IsEnabled="False"
                                        Click="PlayLastRecordingButton_OnClick" />
                                <Button Grid.Column="2"
                                        Content="Actualiser"
                                        Click="RefreshAudioButton_OnClick" />
                            </Grid>
                            <TextBlock Grid.Row="5"
                                       Text="Le dernier PTT valide remplace automatiquement le précédent."
                                       Style="{StaticResource SubtitleStyle}"
                                       VerticalAlignment="Bottom" />
                        </Grid>
                    </Border>

                    <Border x:Name="PttPanel"
                            Grid.Column="4"
                            Style="{StaticResource CardStyle}"
                            Background="{DynamicResource PttIdleBackground}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="31" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="29" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE720;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="PUSH-TO-TALK" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="PttKeyText" Grid.Row="1" Text="CLAVIER : CTRL DROIT" Style="{StaticResource ValueStyle}" FontSize="15" />
                            <TextBlock x:Name="PttJoystickText"
                                       Grid.Row="2"
                                       Text="HOTAS : non assigné"
                                       Foreground="{DynamicResource MutedText}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,3,0,0" />
                            <TextBlock x:Name="PttStateText"
                                       Grid.Row="3"
                                       Text="Relâché"
                                       Foreground="{DynamicResource SecondaryText}"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                            <Button x:Name="AssignJoystickPttButton"
                                    Grid.Row="4"
                                    Content="Assigner un bouton HOTAS"
                                    Click="AssignJoystickPttButton_OnClick" />
                            <Grid Grid.Row="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="ChoosePttButton"
                                        Content="Clavier"
                                        Padding="7,5"
                                        Click="ChoosePttButton_OnClick" />
                                <Button x:Name="ClearJoystickPttButton"
                                        Grid.Column="2"
                                        Content="Effacer HOTAS"
                                        Padding="7,5"
                                        IsEnabled="False"
                                        Click="ClearJoystickPttButton_OnClick" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CompactCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE709;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="SIMULATEUR" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="SimulatorText" Text="-" Style="{StaticResource ValueStyle}" FontSize="15" />
                            <TextBlock x:Name="AircraftText" Text="Avion non détecté" Style="{StaticResource SubtitleStyle}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CompactCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE707;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="POSITION" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="PositionText" Text="-" Style="{StaticResource ValueStyle}" FontSize="14" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="DistanceText" Text="Distance LFBI : -" Style="{StaticResource SubtitleStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource CompactCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7C3;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="ÉTAT DE VOL" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="GroundText" Text="-" Style="{StaticResource ValueStyle}" FontSize="15" />
                            <TextBlock x:Name="AltitudeText" Text="Altitude : -" Style="{StaticResource SubtitleStyle}" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="RadioPolicyCard" Grid.Column="6" Style="{StaticResource CompactCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8D4;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="SERVICE RADIO" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="StationText" Text="-" Style="{StaticResource ValueStyle}" FontSize="14" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="RadioPolicyTitleText" Text="Fréquence non identifiée" Foreground="{DynamicResource Accent}" FontSize="11" FontWeight="SemiBold" Margin="0,3,0,0" />
                            <TextBlock x:Name="RadioPolicyText" Text="Aucune réponse automatique." Style="{StaticResource SubtitleStyle}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CompactCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7C1;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="NAVIGATION" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="HeadingText" Text="Cap : -" Style="{StaticResource ValueStyle}" FontSize="15" />
                            <TextBlock x:Name="SpeedText" Text="IAS - / GS -" Style="{StaticResource SubtitleStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource CompactCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8D4;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="COM 1" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="ComActiveText" Text="Active : -" Style="{StaticResource ValueStyle}" FontSize="14" />
                            <TextBlock x:Name="ComStandbyText" Text="Standby : -" Style="{StaticResource SubtitleStyle}" />
                            <TextBlock x:Name="ComMetaText" Text="Station - / espacement -" Foreground="{DynamicResource Accent}" FontSize="10" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="4" Style="{StaticResource CompactCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE950;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="TRANSPONDEUR" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="XpdrText" Text="-" Style="{StaticResource ValueStyle}" FontSize="15" />
                            <TextBlock Text="Lecture SimConnect" Style="{StaticResource SubtitleStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Grid.Column="6" Style="{StaticResource CompactCardStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE706;" Style="{StaticResource IconTextStyle}" />
                                <TextBlock Text="MÉTÉO LOCALE" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock x:Name="WeatherPrimaryText" Text="Vent - / QNH -" Style="{StaticResource ValueStyle}" FontSize="14" TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="WeatherSecondaryText" Text="Température - / visibilité -" Style="{StaticResource SubtitleStyle}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.55*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE9D5;" Style="{StaticResource IconTextStyle}" />
                                    <TextBlock Text="JOURNAL DIAGNOSTIC" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                                </StackPanel>
                                <Button Grid.Column="1" Content="Effacer" Padding="10,4" Click="ClearLogButton_OnClick" />
                            </Grid>
                            <Border Grid.Row="1" BorderBrush="{DynamicResource Divider}" BorderThickness="0,1,0,0">
                                <TextBox x:Name="LogBox" Style="{StaticResource LogTextBoxStyle}" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="7" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="33" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE9D9;" Style="{StaticResource IconTextStyle}" />
                                    <TextBlock Text="DIAGNOSTIC DE LÉGÈRETÉ" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock x:Name="DiagnosticsPathText"
                                           Grid.Column="1"
                                           Text="logs"
                                           Foreground="{DynamicResource MutedText}"
                                           FontSize="9"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="155"
                                           ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="CPU" Style="{StaticResource LabelStyle}" />
                                    <TextBlock x:Name="CpuDiagnosticText" Text="Mesure..." Style="{StaticResource ValueStyle}" FontSize="15" />
                                    <TextBlock x:Name="CpuAverageDiagnosticText" Text="Moy. - / max -" Style="{StaticResource SubtitleStyle}" FontSize="9" />
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource MetricDividerStyle}" />
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="MÉMOIRE" Style="{StaticResource LabelStyle}" />
                                    <TextBlock x:Name="MemoryDiagnosticText" Text="Mesure..." Style="{StaticResource ValueStyle}" FontSize="15" />
                                    <TextBlock x:Name="ProcessDiagnosticText" Text="Threads - / handles -" Style="{StaticResource SubtitleStyle}" FontSize="9" />
                                </StackPanel>
                                <Border Grid.Column="3" Style="{StaticResource MetricDividerStyle}" />
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="SIMCONNECT" Style="{StaticResource LabelStyle}" />
                                    <TextBlock x:Name="TelemetryDiagnosticText" Text="Mesure..." Style="{StaticResource ValueStyle}" FontSize="15" />
                                    <TextBlock Text="Cadence reçue" Style="{StaticResource SubtitleStyle}" FontSize="9" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="7" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="7" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="MarkerComboBox" SelectedIndex="0">
                                    <ComboBoxItem Content="REPOS SANS SIMU" />
                                    <ComboBoxItem Content="MSFS CONNECTÉ" />
                                    <ComboBoxItem Content="PTT CLAVIER" />
                                    <ComboBoxItem Content="PTT HOTAS" />
                                    <ComboBoxItem Content="OPENTRACK / WEBCAM" />
                                    <ComboBoxItem Content="VOL ACTIF" />
                                    <ComboBoxItem Content="FIN TEST" />
                                </ComboBox>
                                <Button Grid.Column="2" Content="Marquer" Click="MarkDiagnosticsButton_OnClick" />
                                <Button Grid.Column="4" Content="Ouvrir les logs" Click="OpenDiagnosticsFolderButton_OnClick" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="12"
                        Background="{DynamicResource StatusStripBackground}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,7">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="22" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="22" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="22" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="ReadyFooterDot" Width="8" Height="8" Fill="{DynamicResource Warning}" VerticalAlignment="Center" Margin="0,0,7,0" />
                            <TextBlock x:Name="ReadyFooterText" Text="Initialisation" Foreground="{DynamicResource SecondaryText}" FontSize="11" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="SimConnect" Foreground="{DynamicResource SecondaryText}" FontSize="11" Margin="0,0,7,0" />
                            <Ellipse x:Name="SimFooterDot" Width="8" Height="8" Fill="{DynamicResource Warning}" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                            <TextBlock Text="Audio" Foreground="{DynamicResource SecondaryText}" FontSize="11" Margin="0,0,7,0" />
                            <Ellipse x:Name="AudioFooterDot" Width="8" Height="8" Fill="{DynamicResource Warning}" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="5" Orientation="Horizontal">
                            <TextBlock Text="PTT" Foreground="{DynamicResource SecondaryText}" FontSize="11" Margin="0,0,7,0" />
                            <Ellipse x:Name="PttFooterDot" Width="8" Height="8" Fill="{DynamicResource Warning}" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Grid.Column="7" Orientation="Horizontal">
                            <TextBlock Text="Stockage" Foreground="{DynamicResource SecondaryText}" FontSize="11" Margin="0,0,7,0" />
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource Success}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
