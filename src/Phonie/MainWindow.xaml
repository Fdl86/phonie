<Window x:Class="Phonie.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PHONIE — DEV0.2"
        Width="1080"
        Height="880"
        MinWidth="940"
        MinHeight="760"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="PHONIE" FontSize="30" FontWeight="Bold" />
                <TextBlock Text="DEV0.2 · AUDIO &amp; PTT · TERRAIN TEST LFBI"
                           Foreground="{DynamicResource Accent}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,4,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="APPARENCE" Style="{StaticResource LabelStyle}" Margin="0,0,0,4" />
                <ComboBox x:Name="ThemeComboBox"
                          Width="118"
                          SelectionChanged="ThemeComboBox_OnSelectionChanged">
                    <ComboBoxItem Content="Sombre" Tag="Dark" />
                    <ComboBoxItem Content="Clair" Tag="Light" />
                </ComboBox>
            </StackPanel>

            <Button Grid.Column="3"
                    Content="Forcer la reconnexion"
                    Click="ReconnectButton_OnClick"
                    VerticalAlignment="Bottom" />
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="{DynamicResource Warning}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="2">
                    <TextBlock x:Name="ConnectionText" Text="En attente du simulateur" FontSize="17" FontWeight="SemiBold" />
                    <TextBlock Text="Connexion locale automatique · MSFS 2020 et 2024 · aucun ordre de lancement imposé"
                               Style="{StaticResource LabelStyle}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <TextBlock x:Name="LastUpdateText"
                           Grid.Column="3"
                           Text="Aucune donnée"
                           Foreground="{DynamicResource SecondaryText}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1.25*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="MICROPHONE" Style="{StaticResource LabelStyle}" />
                    <ComboBox x:Name="InputDeviceComboBox"
                              Grid.Row="1"
                              Margin="0,7,0,0"
                              SelectionChanged="InputDeviceComboBox_OnSelectionChanged" />
                    <ProgressBar x:Name="MicrophoneLevelBar" Grid.Row="3" Minimum="0" Maximum="100" Value="0" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="SORTIE RADIO" Style="{StaticResource LabelStyle}" />
                    <ComboBox x:Name="OutputDeviceComboBox"
                              Grid.Row="1"
                              Margin="0,7,0,0"
                              SelectionChanged="OutputDeviceComboBox_OnSelectionChanged" />
                    <StackPanel Grid.Row="3" Orientation="Horizontal">
                        <Button Content="Actualiser" Padding="10,5" Click="RefreshAudioButton_OnClick" />
                        <Button x:Name="PlayLastRecordingButton"
                                Content="Écouter le dernier PTT"
                                Padding="10,5"
                                Margin="8,0,0,0"
                                IsEnabled="False"
                                Click="PlayLastRecordingButton_OnClick" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="PttPanel" Grid.Column="4" Style="{StaticResource PanelStyle}" Background="{DynamicResource PttIdleBackground}">
                <StackPanel>
                    <TextBlock Text="PUSH-TO-TALK" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="PttKeyText" Text="CTRL DROIT" Style="{StaticResource ValueStyle}" FontSize="18" />
                    <TextBlock x:Name="PttStateText"
                               Text="Relâché"
                               Foreground="{DynamicResource SecondaryText}"
                               Margin="0,5,0,10" />
                    <Button x:Name="ChoosePttButton" Content="Changer la touche" Padding="10,5" Click="ChoosePttButton_OnClick" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="SIMULATEUR" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="SimulatorText" Text="—" Style="{StaticResource ValueStyle}" />
                    <TextBlock x:Name="AircraftText" Text="Avion non détecté" Foreground="{DynamicResource SecondaryText}" Margin="0,5,0,0" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="POSITION" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="PositionText" Text="—" Style="{StaticResource ValueStyle}" FontSize="17" />
                    <TextBlock x:Name="DistanceText" Text="Distance LFBI : —" Foreground="{DynamicResource SecondaryText}" Margin="0,5,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="ÉTAT DE VOL" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="GroundText" Text="—" Style="{StaticResource ValueStyle}" />
                    <TextBlock x:Name="AltitudeText" Text="Altitude : —" Foreground="{DynamicResource SecondaryText}" Margin="0,5,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="NAVIGATION" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="HeadingText" Text="Cap : —" Style="{StaticResource ValueStyle}" />
                    <TextBlock x:Name="SpeedText" Text="IAS — · GS —" Foreground="{DynamicResource SecondaryText}" Margin="0,5,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="COM 1" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="ComActiveText" Text="Active : —" Style="{StaticResource ValueStyle}" />
                    <TextBlock x:Name="ComStandbyText" Text="Standby : —" Foreground="{DynamicResource SecondaryText}" Margin="0,5,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="4" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="TRANSPONDEUR" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="XpdrText" Text="—" Style="{StaticResource ValueStyle}" />
                    <TextBlock Text="Lecture SimConnect" Foreground="{DynamicResource SecondaryText}" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="8" Style="{StaticResource PanelStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="16,12,16,10">
                    <TextBlock Text="JOURNAL DIAGNOSTIC" Foreground="{DynamicResource SecondaryText}" FontSize="12" FontWeight="SemiBold" />
                    <Button Content="Effacer"
                            HorizontalAlignment="Right"
                            Padding="10,4"
                            Click="ClearLogButton_OnClick" />
                </Grid>

                <TextBox x:Name="LogBox"
                         Grid.Row="1"
                         Background="{DynamicResource LogBackground}"
                         Foreground="{DynamicResource LogForeground}"
                         BorderThickness="0"
                         Padding="16"
                         FontFamily="Consolas"
                         FontSize="12"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled" />
            </Grid>
        </Border>
    </Grid>
</Window>
