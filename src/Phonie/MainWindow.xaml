<Window x:Class="Phonie.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="PHONIE - DEV0.4.1.4 - SIA RADIO &amp; CONTROLLER VOICES"
        Icon="Assets/Phonie.ico"
        Width="1440"
        Height="900"
        MinWidth="1180"
        MinHeight="700"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        StateChanged="MainWindow_OnStateChanged">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38"
                                  ResizeBorderThickness="7"
                                  CornerRadius="8"
                                  GlassFrameThickness="0"
                                  UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource WindowBackground}"
            BorderBrush="{DynamicResource PanelBorder}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource ChromeBackground}"
                    BorderBrush="{DynamicResource Divider}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                        <Image Source="Assets/PhonieIcon.png" Width="22" Height="22" Margin="0,0,8,0" />
                        <TextBlock Text="PHONIE - DEV0.4.1.4 - SIA RADIO &amp; CONTROLLER VOICES"
                                   Foreground="{DynamicResource PrimaryText}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource ChromeButtonStyle}" Content="&#xE921;" ToolTip="Réduire"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True" Click="MinimizeButton_OnClick" />
                    <Button x:Name="MaximizeButton" Grid.Column="2" Style="{StaticResource ChromeButtonStyle}" Content="&#xE922;" ToolTip="Agrandir"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True" Click="MaximizeButton_OnClick" />
                    <Button Grid.Column="3" Style="{StaticResource ChromeButtonStyle}" Content="&#xE8BB;" ToolTip="Fermer"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True" Click="CloseButton_OnClick" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="14,10,14,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="46" />
                    <RowDefinition Height="7" />
                    <RowDefinition Height="46" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="28" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="112" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="118" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" MinHeight="210" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="32" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="Assets/PhonieIcon.png" Width="39" Height="39" Margin="0,0,10,0" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="PHONIE" FontSize="23" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" />
                            <TextBlock Text="DEV0.4.1.4 - SIA RADIO &amp; CONTROLLER VOICES - MODE PORTABLE"
                                       Foreground="{DynamicResource Accent}" FontSize="9" FontWeight="SemiBold" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="APPARENCE" Style="{StaticResource LabelStyle}" Margin="0,0,0,2" />
                        <ComboBox x:Name="ThemeComboBox" Width="118" SelectionChanged="ThemeComboBox_OnSelectionChanged">
                            <ComboBoxItem Content="Sombre" Tag="Dark" />
                            <ComboBoxItem Content="Clair" Tag="Light" />
                        </ComboBox>
                    </StackPanel>
                    <Button Grid.Column="3" Style="{StaticResource AccentButtonStyle}" Content="Forcer la reconnexion"
                            MinWidth="158" Height="31" VerticalAlignment="Bottom" Click="ReconnectButton_OnClick" />
                </Grid>

                <Border Grid.Row="2" Style="{StaticResource CompactCardStyle}" Background="{DynamicResource StatusStripBackground}" Padding="10,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="25" Height="25" CornerRadius="13" Background="{DynamicResource AccentSoft}" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{DynamicResource Warning}" />
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock x:Name="ConnectionText" Text="En attente du simulateur" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock Text="MSFS 2020 / 2024 - données locales - aucune dépendance cloud pour la reconnaissance"
                                       Style="{StaticResource SubtitleStyle}" FontSize="10" Margin="0,1,0,0" />
                        </StackPanel>
                        <TextBlock x:Name="LastUpdateText" Grid.Column="3" Text="Aucune donnée" Foreground="{DynamicResource SecondaryText}"
                                   FontSize="10" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Grid.Row="4" Background="{DynamicResource AccentSoft}" BorderBrush="{DynamicResource Accent}" BorderThickness="1"
                        CornerRadius="7" Padding="9,4">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE946;" Style="{StaticResource IconTextStyle}" FontSize="12" />
                        <TextBlock Text="Désactiver l'ATC et les voix ATC de Microsoft Flight Simulator avant d'utiliser PHONIE."
                                   Foreground="{DynamicResource PrimaryText}" FontSize="10" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="1.05*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="1.15*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CompactCardStyle}" Padding="10,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="4" />
                                <RowDefinition Height="29" />
                                <RowDefinition Height="5" />
                                <RowDefinition Height="29" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE720;" Style="{StaticResource IconTextStyle}" FontSize="14" />
                                <TextBlock Text="MICROPHONE" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            </StackPanel>
                            <ComboBox x:Name="InputDeviceComboBox" Grid.Row="2" SelectionChanged="InputDeviceComboBox_OnSelectionChanged" />
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="7" /><ColumnDefinition Width="105" /></Grid.ColumnDefinitions>
                                <ProgressBar x:Name="MicrophoneLevelBar" Minimum="0" Maximum="100" Value="0" VerticalAlignment="Center" />
                                <ComboBox x:Name="GainComboBox" Grid.Column="2" SelectionChanged="GainComboBox_OnSelectionChanged">
                                    <ComboBoxItem Content="0 dB" Tag="0" /><ComboBoxItem Content="+3 dB" Tag="3" />
                                    <ComboBoxItem Content="+6 dB" Tag="6" /><ComboBoxItem Content="+9 dB" Tag="9" />
                                    <ComboBoxItem Content="+12 dB" Tag="12" /><ComboBoxItem Content="+15 dB" Tag="15" />
                                    <ComboBoxItem Content="+18 dB" Tag="18" />
                                </ComboBox>
                            </Grid>
                            <TextBlock x:Name="MicrophoneSaturationText" Grid.Row="5" Text="Gain PHONIE : +6 dB - signal en attente"
                                       Style="{StaticResource SubtitleStyle}" FontSize="9" Margin="0,2,0,0" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CompactCardStyle}" Padding="10,8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /><RowDefinition Height="4" /><RowDefinition Height="29" />
                                <RowDefinition Height="6" /><RowDefinition Height="29" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE767;" Style="{StaticResource IconTextStyle}" FontSize="14" />
                                <TextBlock Text="SORTIE RADIO" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                            </StackPanel>
                            <ComboBox x:Name="OutputDeviceComboBox" Grid.Row="2" SelectionChanged="OutputDeviceComboBox_OnSelectionChanged" />
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="6" /><ColumnDefinition Width="88" /></Grid.ColumnDefinitions>
                                <Button x:Name="PlayLastRecordingButton" Content="Écouter dernier PTT" IsEnabled="False" Click="PlayLastRecordingButton_OnClick" Padding="7,4" />
                                <Button Grid.Column="2" Content="Actualiser" Click="RefreshAudioButton_OnClick" Padding="7,4" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border x:Name="PttPanel" Grid.Column="4" Style="{StaticResource CompactCardStyle}" Padding="10,8"
                            Background="{DynamicResource PttIdleBackground}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                <RowDefinition Height="*" /><RowDefinition Height="29" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE720;" Style="{StaticResource IconTextStyle}" FontSize="14" />
                                    <TextBlock Text="PUSH-TO-TALK" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock x:Name="PttStateText" Grid.Column="1" Text="Relâché" Foreground="{DynamicResource SecondaryText}"
                                           FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </Grid>
                            <TextBlock x:Name="PttKeyText" Grid.Row="1" Text="CLAVIER : CTRL DROIT" Style="{StaticResource ValueStyle}" FontSize="14" Margin="0,2,0,0" />
                            <TextBlock x:Name="PttJoystickText" Grid.Row="2" Text="HOTAS : non assigné" Foreground="{DynamicResource MutedText}"
                                       FontSize="10" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,1,0,0" />
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="1.3*" /><ColumnDefinition Width="5" /><ColumnDefinition Width="*" /><ColumnDefinition Width="5" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Button x:Name="AssignJoystickPttButton" Content="Assigner HOTAS" Click="AssignJoystickPttButton_OnClick" Padding="6,4" />
                                <Button x:Name="ChoosePttButton" Grid.Column="2" Content="Clavier" Click="ChoosePttButton_OnClick" Padding="6,4" />
                                <Button x:Name="ClearJoystickPttButton" Grid.Column="4" Content="Effacer" Click="ClearJoystickPttButton_OnClick" Padding="6,4" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="8">
                    <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="6" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="6" /><ColumnDefinition Width="*" /><ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="6" /><ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CompactCardStyle}" Padding="9,6"><StackPanel>
                        <TextBlock Text="SIMULATEUR" Style="{StaticResource LabelStyle}" /><TextBlock x:Name="SimulatorText" Text="-" Style="{StaticResource ValueStyle}" FontSize="13" Margin="0,1,0,0" />
                        <TextBlock x:Name="AircraftText" Text="Avion non détecté" Style="{StaticResource SubtitleStyle}" FontSize="9" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="AirportDataText" Text="Airport Data : en attente" Foreground="{DynamicResource Accent}" FontSize="9" TextTrimming="CharacterEllipsis" />
                    </StackPanel></Border>
                    <Border Grid.Column="2" Style="{StaticResource CompactCardStyle}" Padding="9,6"><StackPanel>
                        <TextBlock Text="POSITION" Style="{StaticResource LabelStyle}" /><TextBlock x:Name="PositionText" Text="-" Style="{StaticResource ValueStyle}" FontSize="12" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="DistanceText" Text="Aérodrome géographique : recherche..." Style="{StaticResource SubtitleStyle}" FontSize="9" Margin="0,1,0,0" />
                    </StackPanel></Border>
                    <Border Grid.Column="4" Style="{StaticResource CompactCardStyle}" Padding="9,6"><StackPanel>
                        <TextBlock Text="ÉTAT DE VOL" Style="{StaticResource LabelStyle}" /><TextBlock x:Name="GroundText" Text="-" Style="{StaticResource ValueStyle}" FontSize="13" Margin="0,1,0,0" />
                        <TextBlock x:Name="AltitudeText" Text="Altitude : -" Style="{StaticResource SubtitleStyle}" FontSize="9" Margin="0,1,0,0" />
                    </StackPanel></Border>
                    <Border x:Name="RadioPolicyCard" Grid.Column="6" Style="{StaticResource CompactCardStyle}" Padding="9,6"><StackPanel>
                        <TextBlock Text="SERVICE RADIO" Style="{StaticResource LabelStyle}" /><TextBlock x:Name="StationText" Text="-" Style="{StaticResource ValueStyle}" FontSize="12" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="RadioPolicyTitleText" Text="Fréquence non identifiée" Foreground="{DynamicResource Accent}" FontSize="9" FontWeight="SemiBold" />
                        <TextBlock x:Name="RadioPolicyText" Text="Aucune réponse automatique." Style="{StaticResource SubtitleStyle}" FontSize="8" Margin="0" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="VoiceAssignmentText" Text="Voix : en attente" Foreground="{DynamicResource Accent}" FontSize="8" TextTrimming="CharacterEllipsis" />
                    </StackPanel></Border>

                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CompactCardStyle}" Padding="9,6"><StackPanel>
                        <TextBlock Text="NAVIGATION" Style="{StaticResource LabelStyle}" /><TextBlock x:Name="HeadingText" Text="Cap : -" Style="{StaticResource ValueStyle}" FontSize="13" Margin="0,1,0,0" />
                        <TextBlock x:Name="SpeedText" Text="IAS - / GS -" Style="{StaticResource SubtitleStyle}" FontSize="9" Margin="0,1,0,0" />
                    </StackPanel></Border>
                    <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource CompactCardStyle}" Padding="9,6"><StackPanel>
                        <TextBlock Text="COM1" Style="{StaticResource LabelStyle}" /><TextBlock x:Name="ComActiveText" Text="Active : -" Style="{StaticResource ValueStyle}" FontSize="12" Margin="0,1,0,0" />
                        <TextBlock x:Name="ComStandbyText" Text="Standby : -" Style="{StaticResource SubtitleStyle}" FontSize="9" Margin="0,1,0,0" />
                        <TextBlock x:Name="ComMetaText" Text="Station - / espacement -" Foreground="{DynamicResource Accent}" FontSize="8" TextTrimming="CharacterEllipsis" />
                    </StackPanel></Border>
                    <Border Grid.Row="2" Grid.Column="4" Style="{StaticResource CompactCardStyle}" Padding="9,6"><StackPanel>
                        <TextBlock Text="TRANSPONDEUR" Style="{StaticResource LabelStyle}" /><TextBlock x:Name="XpdrText" Text="-" Style="{StaticResource ValueStyle}" FontSize="13" Margin="0,1,0,0" />
                    </StackPanel></Border>
                    <Border Grid.Row="2" Grid.Column="6" Style="{StaticResource CompactCardStyle}" Padding="9,6"><StackPanel>
                        <TextBlock Text="MÉTÉO LOCALE" Style="{StaticResource LabelStyle}" /><TextBlock x:Name="WeatherPrimaryText" Text="Vent - / QNH -" Style="{StaticResource ValueStyle}" FontSize="12" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="WeatherSecondaryText" Text="Température - / visibilité -" Style="{StaticResource SubtitleStyle}" FontSize="9" Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                    </StackPanel></Border>
                </Grid>

                <Grid Grid.Row="10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="1.45*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="1.05*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="0.9*" /></Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="10,8">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="6" /><RowDefinition Height="*" /><RowDefinition Height="7" /><RowDefinition Height="31" /></Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE8BD;" Style="{StaticResource IconTextStyle}" /><TextBlock Text="ÉCHANGE RADIO" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" /></StackPanel>
                                <TextBlock x:Name="ExchangeLatencyText" Grid.Column="1" Text="En attente du premier PTT" Foreground="{DynamicResource MutedText}" FontSize="9" VerticalAlignment="Center" />
                            </Grid>
                            <Grid Grid.Row="2">
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <TextBlock Text="PILOTE" Style="{StaticResource LabelStyle}" />
                                <TextBox x:Name="PilotTranscriptTextBox" Grid.Row="1" Text="La transcription locale apparaîtra ici."
                                         IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource PrimaryText}" FontSize="13" Padding="0,4" />
                                <TextBlock x:Name="AnalysisText" Grid.Row="2" Text="Station - | Indicatif - | Position - | Intention - | ATIS -"
                                           Foreground="{DynamicResource Accent}" FontSize="9" TextWrapping="Wrap" Margin="0,4,0,2" />
                                <TextBlock x:Name="GroundOperationsText" Grid.Row="3" Text="SOL : graphe en attente - position - piste - occupation"
                                           Foreground="{DynamicResource MutedText}" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,3" />
                                <TextBlock x:Name="ControllerResponseTextBox" Grid.Row="4" Text="PHONIE : aucune réponse générée."
                                           Foreground="{DynamicResource PrimaryText}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                            </Grid>
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="6" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBox x:Name="LabInputTextBox" Text="Poitiers Tour, Fox Golf Alpha Bravo Charlie, au parking aviation générale pour tours de piste avec information Alpha."
                                         VerticalContentAlignment="Center" ToolTip="Mode laboratoire : saisir ou corriger une phrase" />
                                <Button Grid.Column="2" Content="Analyser" Style="{StaticResource AccentButtonStyle}" Click="AnalyzeLabTextButton_OnClick" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="10,8">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="5" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE753;" Style="{StaticResource IconTextStyle}" /><TextBlock Text="INFORMATION ATIS" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" /></StackPanel>
                                <TextBlock x:Name="AtisStateText" Grid.Column="1" Text="EXPÉRIMENTAL" Foreground="{DynamicResource Accent}" FontSize="9" FontWeight="SemiBold" />
                            </Grid>
                            <TextBox x:Name="AtisTextBox" Grid.Row="2" Text="L'ATIS sera généré après résolution de la station radio et réception des données disponibles."
                                     IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource PrimaryText}" FontSize="12" Padding="0,4" />
                            <Grid Grid.Row="3" Margin="0,3,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Text="Révision synthétisée intégralement puis conservée dans cache\atis."
                                           Style="{StaticResource SubtitleStyle}" FontSize="9" VerticalAlignment="Center" />
                                <Button x:Name="PlayAtisButton" Grid.Column="1" Content="Écouter" Padding="7,3" IsEnabled="False" Click="PlayAtisButton_OnClick" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="10,8">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="4" /><RowDefinition Height="Auto" /><RowDefinition Height="8" /><RowDefinition Height="1" /><RowDefinition Height="8" /><RowDefinition Height="Auto" /><RowDefinition Height="5" /><RowDefinition Height="Auto" /><RowDefinition Height="5" /><RowDefinition Height="29" /><RowDefinition Height="4" /><RowDefinition Height="27" /></Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE81E;" Style="{StaticResource IconTextStyle}" /><TextBlock Text="AÉRODROME ACTIF" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" /></StackPanel>
                            <TextBlock x:Name="AirportNameText" Grid.Row="2" Text="Aérodrome - en attente" Style="{StaticResource ValueStyle}" FontSize="13" Margin="0" />
                            <Border Grid.Row="4" Background="{DynamicResource Divider}" />
                            <StackPanel Grid.Row="6">
                                <TextBlock x:Name="AirportSummaryText" Text="Pistes - | parkings - | taxiways -" Style="{StaticResource SubtitleStyle}" FontSize="9" Margin="0" TextWrapping="Wrap" />
                                <TextBlock x:Name="FrequencySummaryText" Text="Fréquences : en attente" Foreground="{DynamicResource Accent}" FontSize="9" TextWrapping="Wrap" Margin="0,3,0,0" />
                                <TextBlock x:Name="SiaRadioDataText" Text="Base SIA : chargement..." Style="{StaticResource SubtitleStyle}" FontSize="8" TextWrapping="Wrap" Margin="0,2,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Row="8">
                                <TextBlock Text="RECONNAISSANCE LOCALE" Style="{StaticResource LabelStyle}" />
                                <ComboBox x:Name="SpeechProfileComboBox" Margin="0,3,0,0" SelectionChanged="SpeechProfileComboBox_OnSelectionChanged">
                                    <ComboBoxItem Content="Whisper Base CPU - rapide" Tag="WhisperBaseCpu" />
                                    <ComboBoxItem Content="Whisper Small CPU - équilibré" Tag="WhisperSmallCpu" />
                                    <ComboBoxItem Content="Whisper Small Vulkan - GPU" Tag="WhisperSmallVulkan" />
                                    <ComboBoxItem Content="Whisper Large-v3 Turbo Vulkan - qualité" Tag="WhisperLargeV3TurboVulkan" />
                                    <ComboBoxItem Content="Vosk FR - expérimental" Tag="VoskFrench" />
                                </ComboBox>
                                <TextBlock x:Name="WhisperStatusText" Text="Profil ASR en attente" Foreground="{DynamicResource PrimaryText}" FontSize="9" TextWrapping="Wrap" Margin="0,3,0,0" />
                                <ProgressBar x:Name="WhisperProgressBar" Height="4" Minimum="0" Maximum="100" Value="0" Margin="0,4,0,0" />
                                <CheckBox x:Name="AutoTranscribeCheckBox" Content="Transcrire automatiquement les PTT" IsChecked="True" FontSize="9" Margin="0,3,0,0"
                                          Checked="AutoTranscribeCheckBox_OnChanged" Unchecked="AutoTranscribeCheckBox_OnChanged" />
                            </StackPanel>
                            <Grid Grid.Row="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" /><ColumnDefinition Width="3" />
                                    <ColumnDefinition Width="*" /><ColumnDefinition Width="3" />
                                    <ColumnDefinition Width="*" /><ColumnDefinition Width="3" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="DownloadWhisperButton" Content="Installer" Click="DownloadWhisperButton_OnClick" Padding="3,4" />
                                <Button x:Name="TranscribeLastButton" Grid.Column="2" Content="Transcrire" Click="TranscribeLastButton_OnClick" Padding="3,4" />
                                <Button x:Name="CompareAsrButton" Grid.Column="4" Content="Comparer" Click="CompareAsrButton_OnClick" Padding="3,4" />
                                <Button x:Name="GpuBenchmarkButton" Grid.Column="6" Content="Bench GPU" Click="GpuBenchmarkButton_OnClick" Padding="3,4" />
                            </Grid>
                            <Grid Grid.Row="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="3" /><ColumnDefinition Width="*" /><ColumnDefinition Width="3" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Button x:Name="RestartAsrButton" Content="Redémarrer ASR" Click="RestartAsrButton_OnClick" Padding="3,3" />
                                <Button x:Name="RestartControllerVoiceButton" Grid.Column="2" Content="Redémarrer voix" Click="RestartControllerVoiceButton_OnClick" Padding="3,3" />
                                <Button x:Name="UpdateRadioDataButton" Grid.Column="4" Content="MAJ SIA" Click="UpdateRadioDataButton_OnClick" Padding="3,3" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="12" Background="{DynamicResource StatusStripBackground}" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1"
                        CornerRadius="8" Padding="10,5">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="18" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="18" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="18" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal"><Ellipse x:Name="ReadyFooterDot" Width="8" Height="8" Fill="{DynamicResource Warning}" VerticalAlignment="Center" Margin="0,0,6,0" /><TextBlock x:Name="ReadyFooterText" Text="Initialisation" Foreground="{DynamicResource SecondaryText}" FontSize="10" /></StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"><TextBlock Text="SimConnect" Foreground="{DynamicResource SecondaryText}" FontSize="10" Margin="0,0,6,0" /><Ellipse x:Name="SimFooterDot" Width="8" Height="8" Fill="{DynamicResource Warning}" VerticalAlignment="Center" /></StackPanel>
                        <StackPanel Grid.Column="3" Orientation="Horizontal"><TextBlock Text="Audio" Foreground="{DynamicResource SecondaryText}" FontSize="10" Margin="0,0,6,0" /><Ellipse x:Name="AudioFooterDot" Width="8" Height="8" Fill="{DynamicResource Warning}" VerticalAlignment="Center" /></StackPanel>
                        <StackPanel Grid.Column="5" Orientation="Horizontal"><TextBlock Text="PTT" Foreground="{DynamicResource SecondaryText}" FontSize="10" Margin="0,0,6,0" /><Ellipse x:Name="PttFooterDot" Width="8" Height="8" Fill="{DynamicResource Warning}" VerticalAlignment="Center" /></StackPanel>
                        <Button Grid.Column="7" Content="Diagnostic" Padding="9,3" Click="ToggleDiagnosticsButton_OnClick" />
                    </Grid>
                </Border>

                <Border x:Name="DiagnosticOverlay" Grid.Row="0" Grid.RowSpan="13" Panel.ZIndex="20" Visibility="Collapsed"
                        Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource Accent}" BorderThickness="1" CornerRadius="9" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="38" /><RowDefinition Height="8" /><RowDefinition Height="72" /><RowDefinition Height="8" /><RowDefinition Height="260" /><RowDefinition Height="8" /><RowDefinition Height="*" /><RowDefinition Height="8" /><RowDefinition Height="31" /></Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="&#xE9D9;" Style="{StaticResource IconTextStyle}" /><TextBlock Text="DIAGNOSTIC PHONIE" Foreground="{DynamicResource PrimaryText}" FontSize="16" FontWeight="SemiBold" /></StackPanel>
                            <Button Grid.Column="1" Content="Fermer" Click="ToggleDiagnosticsButton_OnClick" />
                        </Grid>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CompactCardStyle}"><StackPanel><TextBlock Text="CPU" Style="{StaticResource LabelStyle}" /><TextBlock x:Name="CpuDiagnosticText" Text="Mesure..." Style="{StaticResource ValueStyle}" FontSize="15" /><TextBlock x:Name="CpuAverageDiagnosticText" Text="Moy. - / max -" Style="{StaticResource SubtitleStyle}" FontSize="9" /></StackPanel></Border>
                            <Border Grid.Column="2" Style="{StaticResource CompactCardStyle}"><StackPanel><TextBlock Text="MÉMOIRE" Style="{StaticResource LabelStyle}" /><TextBlock x:Name="MemoryDiagnosticText" Text="Mesure..." Style="{StaticResource ValueStyle}" FontSize="15" /><TextBlock x:Name="ProcessDiagnosticText" Text="Threads - / handles -" Style="{StaticResource SubtitleStyle}" FontSize="9" /></StackPanel></Border>
                            <Border Grid.Column="4" Style="{StaticResource CompactCardStyle}"><StackPanel><TextBlock Text="SIMCONNECT" Style="{StaticResource LabelStyle}" /><TextBlock x:Name="TelemetryDiagnosticText" Text="Mesure..." Style="{StaticResource ValueStyle}" FontSize="15" /><TextBlock x:Name="DiagnosticsPathText" Text="logs" Style="{StaticResource SubtitleStyle}" FontSize="9" TextTrimming="CharacterEllipsis" /></StackPanel></Border>
                        </Grid>
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="0.9*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="1.1*" /></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="9,7">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="5" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE7BA;" Style="{StaticResource IconTextStyle}" /><TextBlock Text="DIAGNOSTIC ROULAGE" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" /></StackPanel>
                                    <TextBox x:Name="GroundRoutingDiagnosticTextBox" Grid.Row="2" Text="Diagnostic du graphe, du trafic et des itinéraires en attente."
                                             IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                             Background="Transparent" BorderThickness="0" Foreground="{DynamicResource SecondaryText}" FontFamily="Consolas" FontSize="10" Padding="0" />
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="7">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="5" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE707;" Style="{StaticResource IconTextStyle}" /><TextBlock Text="CARTE DU ROULAGE" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" /></StackPanel>
                                        <TextBlock x:Name="GroundMapStatusText" Grid.Column="1" Text="EN ATTENTE" Style="{StaticResource SubtitleStyle}" FontSize="9" />
                                    </Grid>
                                    <Border Grid.Row="2" Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource Divider}" BorderThickness="1" CornerRadius="5" ClipToBounds="True">
                                        <Canvas x:Name="GroundMapCanvas" Background="Transparent" SizeChanged="GroundMapCanvas_OnSizeChanged" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                        <Border Grid.Row="6" Style="{StaticResource CardStyle}" Padding="0"><TextBox x:Name="LogBox" Style="{StaticResource LogTextBoxStyle}" /></Border>
                        <Grid Grid.Row="8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="6" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="6" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="6" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="6" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <ComboBox x:Name="MarkerComboBox" SelectedIndex="0"><ComboBoxItem Content="REPOS SANS SIMU" /><ComboBoxItem Content="MSFS CONNECTÉ" /><ComboBoxItem Content="PTT CLAVIER" /><ComboBoxItem Content="PTT HOTAS" /><ComboBoxItem Content="VOL ACTIF" /><ComboBoxItem Content="FIN TEST" /></ComboBox>
                            <Button Grid.Column="2" Content="Marquer" Click="MarkDiagnosticsButton_OnClick" />
                            <Button Grid.Column="4" Content="Recharger aérodrome" Click="RequestLfbiAirportDataButton_OnClick" />
                            <Button Grid.Column="6" Content="Ouvrir logs" Click="OpenDiagnosticsFolderButton_OnClick" />
                            <Button Grid.Column="8" Content="Effacer journal" Click="ClearLogButton_OnClick" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
