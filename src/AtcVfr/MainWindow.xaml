<Window x:Class="AtcVfr.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ATC VFR — DEV0.1"
        Width="980"
        Height="720"
        MinWidth="820"
        MinHeight="620"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="ATC VFR" FontSize="28" FontWeight="Bold" />
                <TextBlock Text="DEV0.1 · SOCLE SIMCONNECT · TERRAIN TEST LFBI"
                           Foreground="{StaticResource Accent}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,4,0,0" />
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Forcer la reconnexion"
                    Click="ReconnectButton_OnClick"
                    VerticalAlignment="Center" />
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PanelStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="{StaticResource Warning}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="2">
                    <TextBlock x:Name="ConnectionText" Text="En attente du simulateur" FontSize="17" FontWeight="SemiBold" />
                    <TextBlock Text="Connexion locale automatique · aucun ordre de lancement imposé"
                               Style="{StaticResource LabelStyle}"
                               Margin="0,3,0,0" />
                </StackPanel>
                <TextBlock x:Name="LastUpdateText"
                           Grid.Column="3"
                           Text="Aucune donnée"
                           Foreground="{StaticResource SecondaryText}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="SIMULATEUR" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="SimulatorText" Text="—" Style="{StaticResource ValueStyle}" />
                    <TextBlock x:Name="AircraftText" Text="Avion non détecté" Foreground="{StaticResource SecondaryText}" Margin="0,5,0,0" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="POSITION" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="PositionText" Text="—" Style="{StaticResource ValueStyle}" FontSize="17" />
                    <TextBlock x:Name="DistanceText" Text="Distance LFBI : —" Foreground="{StaticResource SecondaryText}" Margin="0,5,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="ÉTAT DE VOL" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="GroundText" Text="—" Style="{StaticResource ValueStyle}" />
                    <TextBlock x:Name="AltitudeText" Text="Altitude : —" Foreground="{StaticResource SecondaryText}" Margin="0,5,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="NAVIGATION" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="HeadingText" Text="Cap : —" Style="{StaticResource ValueStyle}" />
                    <TextBlock x:Name="SpeedText" Text="IAS — · GS —" Foreground="{StaticResource SecondaryText}" Margin="0,5,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="COM 1" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="ComActiveText" Text="Active : —" Style="{StaticResource ValueStyle}" />
                    <TextBlock x:Name="ComStandbyText" Text="Standby : —" Foreground="{StaticResource SecondaryText}" Margin="0,5,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="4" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Text="TRANSPONDEUR" Style="{StaticResource LabelStyle}" />
                    <TextBlock x:Name="XpdrText" Text="—" Style="{StaticResource ValueStyle}" />
                    <TextBlock Text="Lecture uniquement dans DEV0.1" Foreground="{StaticResource SecondaryText}" Margin="0,5,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="6" Style="{StaticResource PanelStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="16,12,16,10">
                    <TextBlock Text="JOURNAL DIAGNOSTIC" Foreground="{StaticResource SecondaryText}" FontSize="12" FontWeight="SemiBold" />
                    <Button Content="Effacer"
                            HorizontalAlignment="Right"
                            Padding="10,4"
                            Click="ClearLogButton_OnClick" />
                </Grid>

                <TextBox x:Name="LogBox"
                         Grid.Row="1"
                         Background="#0E1218"
                         Foreground="#C8D0DA"
                         BorderThickness="0"
                         Padding="16"
                         FontFamily="Consolas"
                         FontSize="12"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled" />
            </Grid>
        </Border>
    </Grid>
</Window>
